# Copy to .env and fill in. NEVER commit .env (it is git-ignored; repo is public).

# OpenAI / Codex — used by the agent host for headless Codex CLI auth
OPENAI_API_KEY=sk-...

# Codex
CODEX_BIN=codex
CODEX_MODEL=gpt-5.6-sol

# Auth (Clerk) — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# "clerk" in normal use; "local" enables the cookie-session fallback for local judge runs (no Clerk needed).
# BOTH processes read it from this file (the web app via scripts/next-with-port.mjs) —
# in local mode this is what keeps Clerk JS out of the browser entirely.
AUTH_MODE=clerk

# Hosted demo gate — required for POST /auth/demo-login ("Explore as Alex")
ACCESS_CODE=

# Ports / paths (defaults shown)
WEB_PORT=3000
SERVER_PORT=8787
RELAY_PORT=8788
DATA_DIR=./data

# Production only
APP_ORIGIN=https://eduagent.aiquantized.com
