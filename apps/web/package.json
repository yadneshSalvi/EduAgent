  "description": "EduAgent web app — Next.js App Router, Tailwind v4 + shadcn/ui, Clerk auth (see plans/04_frontend.md)",
  "scripts": {
    "dev": "node scripts/vendor-monaco.mjs && node scripts/next-with-port.mjs dev",
