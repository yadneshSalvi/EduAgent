# Committed DUMMY values for the local compose smoke test ONLY — never real
# secrets. The dummy key still exercises the headless-auth path: `codex login
# --with-api-key` writes auth.json without a network call, so /healthz shows
# codex:ok; actual turns would 401 (fine — the smoke test runs none).
AUTH_MODE=local
OPENAI_API_KEY=sk-dummy-local-compose-smoke-test
SESSION_SECRET=local-compose-smoke-test-secret-0123456789
LOG_LEVEL=info
SITE_ADDRESS=:8090
PUBLIC_ORIGIN=http://localhost:8090
APP_ORIGIN=http://localhost:8090
