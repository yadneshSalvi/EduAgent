# EduAgent web (Next.js standalone) — build from the REPO ROOT context:
#   docker build -f deploy/Dockerfile.web \
#     --build-arg NEXT_PUBLIC_SERVER_URL=https://eduagent.aiquantized.com .
#
# NEXT_PUBLIC_* vars are inlined into the client bundle at BUILD time
# (apps/web/README.md), so the public origin and the Clerk publishable key
# must arrive as build args — exporting them at `docker run` time does nothing.

FROM node:22-slim AS deps
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0 \
    PNPM_HOME=/pnpm
RUN corepack enable
WORKDIR /app
# Manifests only, so dependency layers cache across source edits. ALL
# workspace manifests must be present — frozen-lockfile validates the full
# importer set even under --filter.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json apps/web/package.json
COPY apps/server/package.json apps/server/package.json
COPY packages/shared/package.json packages/shared/package.json
COPY packages/mcp-ui-tools/package.json packages/mcp-ui-tools/package.json
RUN pnpm install --frozen-lockfile --filter @eduagent/web...

FROM deps AS build
# Behind Caddy, web and API share one origin (plans/08 §2) — bake it, or the
# runtime fallback in src/lib/api.ts targets <hostname>:8787 and misses.
ARG NEXT_PUBLIC_SERVER_URL
ARG NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
ENV NEXT_PUBLIC_SERVER_URL=$NEXT_PUBLIC_SERVER_URL \
    NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=$NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY \
    NEXT_STANDALONE=1 \
    NEXT_TELEMETRY_DISABLED=1
COPY tsconfig.base.json tsconfig.json ./
COPY packages/shared packages/shared
COPY apps/web apps/web
RUN pnpm --filter @eduagent/web run build

FROM node:22-slim AS runtime
ENV NODE_ENV=production \
    PORT=3000 \
    HOSTNAME=0.0.0.0
WORKDIR /app
# Standalone output bundles server.js + the pruned node_modules it needs;
# static assets and /public are served by the same server but not traced.
COPY --from=build --chown=node:node /app/apps/web/.next/standalone ./
COPY --from=build --chown=node:node /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build --chown=node:node /app/apps/web/public ./apps/web/public
USER node
EXPOSE 3000
CMD ["node", "apps/web/server.js"]
