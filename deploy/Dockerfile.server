# EduAgent agent host — build from the REPO ROOT context:
#   docker build -f deploy/Dockerfile.server .
#
# The server runs TS from source via tsx (plans/01 §2), spawns
# `codex app-server` as a stdio child, and spawns the mcp-ui-tools stdio
# server from packages/ — so the image carries the pnpm workspace for
# @eduagent/server + @eduagent/mcp-ui-tools (+shared), never apps/web.

FROM node:22-slim AS base
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
# git: user workspaces are real git repos (simple-git + agent-run git).
# openssl/ca-certificates: Prisma engines + HTTPS to the OpenAI API.
RUN apt-get update \
    && apt-get install -y --no-install-recommends git ca-certificates openssl \
    && rm -rf /var/lib/apt/lists/*
# Codex CLI, EXACTLY the version the protocol notes pin (docs/PROTOCOL_NOTES.md:
# codex-cli 0.144.4). Install source: the official `@openai/codex` npm package —
# same distribution the README tells judges to install. Never bump this
# independently of the protocol notes.
RUN npm install -g @openai/codex@0.144.4 && codex --version
RUN corepack enable

FROM base AS deps
WORKDIR /app
# ALL workspace manifests must be present — frozen-lockfile validates the
# full importer set even under --filter.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/server/package.json apps/server/package.json
COPY apps/web/package.json apps/web/package.json
COPY packages/shared/package.json packages/shared/package.json
COPY packages/mcp-ui-tools/package.json packages/mcp-ui-tools/package.json
# Dev deps stay: tsx and prisma are the runtime (tsx-from-source repo).
RUN pnpm install --frozen-lockfile \
    --filter @eduagent/server... \
    --filter @eduagent/mcp-ui-tools...

FROM deps AS runtime
ENV NODE_ENV=production
COPY tsconfig.base.json tsconfig.json ./
COPY packages/shared packages/shared
COPY packages/mcp-ui-tools packages/mcp-ui-tools
COPY apps/server apps/server
# Generate the Prisma client for THIS platform (linux) at build time;
# migrate deploy runs at container start, once /data is mounted.
RUN pnpm --filter @eduagent/server exec prisma generate
COPY deploy/server-entrypoint.sh /usr/local/bin/server-entrypoint.sh
RUN chmod +x /usr/local/bin/server-entrypoint.sh \
    # /data is the single state volume (SQLite + workspaces + codex home).
    # Owning it as node here makes the named volume inherit that ownership.
    && mkdir -p /data && chown -R node:node /data /app
USER node
ENV DATA_DIR=/data \
    CODEX_HOME=/data/codex-home
EXPOSE 8787
ENTRYPOINT ["/usr/local/bin/server-entrypoint.sh"]
