# EduAgent VPS deployment env — copy to .env.production on the VPS and fill
# in. NEVER commit .env.production (git-ignored; repo is public). Compose must
# always run with `--env-file .env.production` (deploy/deploy.sh does) so
# these values drive both ${…} interpolation and the server container env.

# ── Public identity ─────────────────────────────────────────────────────────
# Caddy site address (bare host → auto-TLS via ACME). DNS A record must point
# at this VPS before first boot, or cert provisioning fails.
SITE_ADDRESS=eduagent.aiquantized.com
# Full public origin. Baked into the web bundle at IMAGE BUILD time
# (NEXT_PUBLIC_SERVER_URL) — changing it requires `compose build`, not just
# up. Also the server's APP_ORIGIN (CORS allowlist + cookie context).
PUBLIC_ORIGIN=https://eduagent.aiquantized.com
APP_ORIGIN=https://eduagent.aiquantized.com

# ── Secrets ─────────────────────────────────────────────────────────────────
# OpenAI key for headless codex auth (entrypoint pipes it into `codex login
# --with-api-key`, then unsets it; auth.json lives on the /data volume).
# Put a hard budget cap on this key (plans/08 §3) — it powers a public demo.
OPENAI_API_KEY=sk-REPLACE_ME
# Gates POST /auth/demo-login ("Explore as Alex"). The server FAILS CLOSED
# when unset (503) — set it, and share it only via Devpost testing
# instructions. Pick something judges can type: e.g. two words + digits.
ACCESS_CODE=REPLACE_ME
# Signs the AUTH_MODE=local session cookie. Unused in clerk mode but set a
# strong value anyway (32+ random chars): openssl rand -hex 32
SESSION_SECRET=REPLACE_ME_openssl_rand_hex_32

# ── Auth (Clerk) — https://dashboard.clerk.com, PRODUCTION instance ─────────
AUTH_MODE=clerk
# Publishable key is ALSO baked into the web bundle at build time.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_ME
CLERK_SECRET_KEY=sk_live_REPLACE_ME

# ── Codex ───────────────────────────────────────────────────────────────────
# Binary + model are pinned in the image / config defaults (codex-cli 0.144.4,
# gpt-5.6-sol per docs/PROTOCOL_NOTES.md). Override only with a matching
# protocol re-verification.
#CODEX_MODEL=gpt-5.6-sol

# ── Abuse limits (plans/08 §5) ──────────────────────────────────────────────
# Max USER turn starts per profile per local day (0 = off). System turns
# (greeting, grading) are exempt. 60 ≈ a generous judging session without
# letting one profile burn the API budget.
DAILY_TURN_QUOTA=60
# "1" registers @fastify/rate-limit: ~300 req/min/IP global, 10/min on the
# credential routes (/auth/demo-login, /auth/local-login); /healthz exempt.
# Also switches Fastify to trustProxy (per-IP keys come from Caddy's
# X-Forwarded-For) — leave unset for direct local runs.
RATE_LIMITS=1

# ── Logging ─────────────────────────────────────────────────────────────────
# info is the prod default (session tokens etc. only surface at debug).
LOG_LEVEL=info
